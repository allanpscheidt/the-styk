<Window x:Class="TheStyk.UI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sobre o The Styk"
        Height="420" Width="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F7"
        ShowInTaskbar="True"
        Topmost="True">
    
    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0062CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004C99"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Logo -->
            <RowDefinition Height="Auto"/>
            <!-- Título -->
            <RowDefinition Height="Auto"/>
            <!-- Versão -->
            <RowDefinition Height="Auto"/>
            <!-- Descrição -->
            <RowDefinition Height="*"/>
            <!-- Direitos Autorais -->
            <RowDefinition Height="Auto"/>
            <!-- Botão de Fechar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo Redondo do App -->
        <Border Grid.Row="0" Width="80" Height="80" CornerRadius="16" HorizontalAlignment="Center" Margin="0,10,0,12">
            <Border.Background>
                <ImageBrush ImageSource="pack://application:,,,/assets/logo.png" Stretch="UniformToFill"/>
            </Border.Background>
        </Border>

        <!-- Nome do App -->
        <TextBlock Grid.Row="1" Text="The Styk" 
                   FontSize="20" FontWeight="Bold" 
                   Foreground="#1C1C1E" FontFamily="Segoe UI" 
                   HorizontalAlignment="Center" Margin="0,0,0,2"/>

        <!-- Versão -->
        <TextBlock Grid.Row="2" Text="Versão 1.0.0 (Windows)" 
                   FontSize="12" Foreground="#8E8E93" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <!-- Descrição e Links -->
        <TextBlock Grid.Row="3" FontSize="12" Foreground="#3A3A3C" 
                   TextWrapping="Wrap" TextAlignment="Center" 
                   LineHeight="18" FontFamily="Segoe UI"
                   HorizontalAlignment="Center" Margin="15,0,15,15">
            Notas adesivas que grudam nas suas pastas.
            <LineBreak/><LineBreak/>
            Código-fonte: <Hyperlink NavigateUri="https://github.com/allanpscheidt/the-styk" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#007AFF">github.com/allanpscheidt/the-styk</Hyperlink>
            <LineBreak/>
            Download: <Hyperlink NavigateUri="https://setor101.com.br/apps/styk" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#007AFF">setor101.com.br/apps/styk</Hyperlink>
        </TextBlock>

        <!-- Direitos Autorais / Licença -->
        <StackPanel Grid.Row="4" Margin="0,0,0,20">
            <TextBlock Text="© 2026 Allan Pscheidt" 
                       FontSize="10" Foreground="#8E8E93" 
                       TextAlignment="Center" Margin="0,0,0,2"/>
            <TextBlock Text="Todos os direitos reservados. Licenciado sob Licença MIT." 
                       FontSize="9" Foreground="#AEAEB2" 
                       TextAlignment="Center"/>
        </StackPanel>

        <!-- Botão de Fechar -->
        <Button Grid.Row="5" Style="{StaticResource ModernButtonStyle}" 
                Content="Fechar" Click="CloseButton_Click" 
                HorizontalAlignment="Center" Width="100"/>
    </Grid>
</Window>
